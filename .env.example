# Example environment variables for local development
# Copy this to `.env.local` and replace the placeholders with real values.
# Do NOT commit your real keys. Add `.env.local` to .gitignore.

# Supabase (public/anon) client settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Gemini / Google GenAI API key (used by AI features and Live Curator)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Some code references `API_KEY` as well — keep in sync
VITE_API_KEY=your-gemini-api-key

# Optional: override base URL for previewing or proxying
# BASE_URL=http://localhost:5173
